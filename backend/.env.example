# Copy to .env for local (non-Docker) development. Defaults assume the
# docker-compose services are exposed on localhost.
APP_PORT=8080
DATABASE_URL=postgres://jago:jago@localhost:5432/jago?sslmode=disable
REDIS_URL=redis://localhost:6379/0
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

JWT_SECRET=dev-secret-change-me
JWT_TTL=24h

# Admin dashboard (frontend/) — static fallback key sent as the X-Admin-Key
# header (handy for curl/tooling; the dashboard normally uses phone+OTP login).
ADMIN_API_KEY=admin-secret

# Default admin seeded on boot when admin_users is empty (phone+OTP login).
ADMIN_SEED_NAME=Super Admin
ADMIN_SEED_PHONE=81200000000

# WAHA (WhatsApp HTTP API) for delivering admin OTPs. Leave WAHA_BASE_URL empty
# to disable sending (demo mode still works — the OTP is OTP_DEMO_CODE).
WAHA_BASE_URL=
WAHA_SESSION=default
WAHA_API_KEY=

# CORS: web origins allowed to call the API from a browser (comma-separated).
# "*" allows any origin (auth is via headers, not cookies, so this is safe).
CORS_ALLOWED_ORIGINS=*

OTP_TTL=5m
# When true the OTP is always OTP_DEMO_CODE (matches the Flutter app's mock).
OTP_DEMO_MODE=true
OTP_DEMO_CODE=123456

# OTP rate limiting (Redis-backed)
OTP_MAX_REQUESTS=5
OTP_RATE_WINDOW=15m
OTP_MAX_VERIFY_ATTEMPTS=5

# Structured logging (slog)
LOG_LEVEL=info   # debug | info | warn | error
LOG_FORMAT=json  # json | text
