# Copy to .env.local for local overrides. All client env vars must be VITE_*.

# Default backend base URL pre-filled on the login form. The client appends
# /api/v1 automatically. Leave unset to default to http://localhost:8080.
VITE_API_BASE_URL=http://localhost:8080

# Accepted OTP code for the demo login. Leave unset to default to 123456.
VITE_DEMO_OTP=123456
